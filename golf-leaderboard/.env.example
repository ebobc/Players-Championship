# Slash Golf API (via RapidAPI)
# 1. Go to https://slashgolf.dev and click "Sign Up" for the free Basic tier
# 2. Or go directly to https://rapidapi.com/slashgolf/api/live-golf-data/pricing
# 3. Subscribe to Basic (free) - 250 calls/month
# 4. Copy your API key from the RapidAPI dashboard (after subscribing)
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Tournament ID (auto-detected from schedule if not set)
# 2026 Players Championship = 011. Get tournId from /api/golf/schedule?year=2026
# TOURNAMENT_ID=011

# Optional: Tournament year (default: 2026)
# Note: API may not have data until tournament approaches
# TOURNAMENT_YEAR=2026

# Optional: Access code to restrict who can UPDATE the leaderboard
# If set, anyone can VIEW cached data, but only the owner (with this code) can Load/Refresh/Check holes
# LEADERBOARD_SECRET=your_secret_code

# Optional: Redis for persistent cache (data viewable for 5 hours after you refresh)
# Add Upstash Redis via Vercel Marketplace, or set these manually:
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=your_token
